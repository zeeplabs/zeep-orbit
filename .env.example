# Required
DATABASE_URL=postgres://zeep:zeep@localhost:5432/zeep?sslmode=disable
DASHBOARD_BOOTSTRAP_SECRET=change-me-in-production

# Google OAuth (dashboard login)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URL=https://orbit.zeeplabs.com/dashboard/api/auth/google/callback
# GOOGLE_ALLOWED_DOMAINS=zeeplabs.com, zeepfly.com

# Encryption key for sensitive data at rest (defaults to DASHBOARD_BOOTSTRAP_SECRET)
# GOOGLE_OAUTH_ENCRYPTION_KEY=

# White-label branding
# BRAND_THEME=azure
# BRAND_COMPANY_NAME=Zeep Tecnologia

# App JWT secrets (one per app in apps.yaml)
# ASSETS_JWT_SECRET=change-me-in-production

# Object storage (S3-compatible: AWS S3, DO Spaces, MinIO, etc.)
# STORAGE_BUCKET=my-bucket
# STORAGE_REGION=us-east-1
# STORAGE_ENDPOINT=https://s3.amazonaws.com
# STORAGE_ACCESS_KEY_ID=your-access-key
# STORAGE_SECRET_ACCESS_KEY=your-secret-key

# Logging
# LOG_LEVEL=debug
